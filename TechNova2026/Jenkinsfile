pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    parameters {
        string(name: 'IMAGE_NAME', defaultValue: 'technova2026', description: 'Docker image name')
        string(name: 'DOCKERHUB_REPO', defaultValue: '', description: 'Docker Hub repository (optional)')
        booleanParam(name: 'DEPLOY_TO_K8S', defaultValue: true, description: 'Deploy to Kubernetes')
    }

    environment {
        IMAGE_TAG = "${env.BUILD_NUMBER}"
        FULL_IMAGE = "${params.IMAGE_NAME}:${env.BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    dir('TechNova2026') {
                        env.GIT_SHA = sh(
                            script: 'git rev-parse --short HEAD',
                            returnStdout: true
                        ).trim()
                    }
                }
                echo "Checked out commit ${env.GIT_SHA}"
            }
        }

        stage('Lint / Sanity Check') {
            steps {
                dir('TechNova2026') {
                    sh '''
                        echo "Checking required files..."

                        pwd
                        ls -la

                        test -f index.html
                        test -f Dockerfile
                        test -d k8s

                        echo "All required files found."
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('TechNova2026') {
                    sh """
                        docker build \
                          --build-arg APP_VERSION=${IMAGE_TAG} \
                          --build-arg GIT_SHA=${GIT_SHA} \
                          -t ${FULL_IMAGE} \
                          -t ${params.IMAGE_NAME}:latest \
                          .
                    """
                }
            }
        }

        stage('Docker Push') {
            when {
                expression { return params.DOCKERHUB_REPO?.trim() }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    dir('TechNova2026') {
                        sh """
                            echo "\$DOCKER_PASS" | docker login -u "\$DOCKER_USER" --password-stdin
                            docker tag ${FULL_IMAGE} ${params.DOCKERHUB_REPO}:${IMAGE_TAG}
                            docker tag ${FULL_IMAGE} ${params.DOCKERHUB_REPO}:latest
                            docker push ${params.DOCKERHUB_REPO}:${IMAGE_TAG}
                            docker push ${params.DOCKERHUB_REPO}:latest
                            docker logout
                        """
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            when {
                expression { return params.DEPLOY_TO_K8S }
            }
            steps {
                dir('TechNova2026') {
                    script {
                        def deployImage = params.DOCKERHUB_REPO?.trim()
                            ? "${params.DOCKERHUB_REPO}:${IMAGE_TAG}"
                            : "${FULL_IMAGE}"

                        sh """
                            cd k8s
                            kubectl apply -f namespace.yaml
                            kubectl apply -k .
                            kubectl -n technova set image deployment/technova-web technova-web=${deployImage} --record || true
                            kubectl -n technova rollout status deployment/technova-web --timeout=120s
                        """
                    }
                }
            }
        }

        stage('Smoke Test') {
            when {
                expression { return params.DEPLOY_TO_K8S }
            }
            steps {
                sh '''
                    kubectl -n technova get pods -o wide
                    kubectl -n technova get svc technova-web -o wide
                '''
            }
        }
    }

    post {
        success {
            echo "Build ${IMAGE_TAG} completed successfully."
        }

        failure {
            echo "Build failed. Check Console Output."
        }

        always {
            sh 'docker image prune -f || true'
        }
    }
}

